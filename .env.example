# Copy to .env.local (never commit secrets)
# See SETUP.md and AGENTS.md (Environment Variables) for what each URL is for.

# --- AWS Lambda Function URLs (server-only — no NEXT_PUBLIC_) ---
# AUTH_LAMBDA_URL=
# LOOKUP_LAMBDA_URL=
# ORDER_LAMBDA_URL=
# ADMIN_LAMBDA_URL=
# RESELLER_LAMBDA_URL=   # reseller dashboard — deploy from lambda functions/reseller_handler/

# Cloudflare R2 (server-only — no NEXT_PUBLIC_)
R2_ACCOUNT_ID=
R2_BUCKET_NAME=pic-uploads
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Signs short-lived reseller upload-session tokens (openssl rand -hex 32)
R2_UPLOAD_TOKEN_SECRET=

# Signs guest crypto pay tokens for white-label / public track (same value on LOOKUP Lambda)
PAY_TOKEN_SECRET=

# Local subdomain testing (manny.localhost): comma-separated reseller ids allowed when NODE_ENV=development if Lambda does not know that slug
# RESELLER_UPLOAD_DEV_SLUGS=manny,idpirate_test_reseller
# Optional: if LOOKUP_LAMBDA_URL is unset in production/preview, set to true to allow reseller upload sessions without Lambda (use sparingly)
# ALLOW_RESELLER_UPLOAD_WITHOUT_LOOKUP=

# --- Crypto payment gateway (optional — site works without it) ---
# AWS Lambda: CRYPTO_PAYMENTS_ENABLED=false  # disable gateway without removing code
# LOOKUP: PAY_TOKEN_SECRET= (must match Vercel), COINGECKO_API_KEY= (optional)
# payment_watcher: ETHERSCAN_API_KEY=, SOLANA_RPC_URL=, HELIUS_API_KEY= (preferred for Solana)
# Docs: integration/payments/README.md, integration/payments/OPS_RUNBOOK.md
